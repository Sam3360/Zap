rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function groupDoc(groupId) {
      return get(/databases/$(database)/documents/roomsMeta/$(groupId));
    }

    function dmDoc(dmId) {
      return get(/databases/$(database)/documents/dms/$(dmId));
    }

    function isGroupMember(groupId) {
      let group = groupDoc(groupId).data;
      return signedIn() && (
        group.type != 'private' ||
        group.owner == request.auth.uid ||
        group.members[request.auth.uid] == true
      );
    }

    function isGroupOwner(groupId) {
      return signedIn() && groupDoc(groupId).data.owner == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == userId;
      match /notes/{noteId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }
    }

    match /messages/{messageId} {
      allow read, create: if signedIn();
      allow update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /roomsMeta/{groupId} {
      allow read: if signedIn() && (
        resource.data.type != 'private' ||
        resource.data.owner == request.auth.uid ||
        resource.data.members[request.auth.uid] == true
      );
      allow create: if signedIn() && request.resource.data.owner == request.auth.uid;
      allow update, delete: if isGroupOwner(groupId);
    }

    match /rooms/{groupId}/messages/{messageId} {
      allow read, create: if isGroupMember(groupId);
      allow update, delete: if signedIn() && (
        resource.data.uid == request.auth.uid || isGroupOwner(groupId)
      );
    }

    match /rooms/{groupId}/typing/{typingId} {
      allow read, write: if isGroupMember(groupId);
    }

    match /dms/{dmId} {
      allow read, write: if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if signedIn() && request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        allow read, create: if signedIn() && request.auth.uid in dmDoc(dmId).data.participants;
        allow update, delete: if signedIn() && resource.data.uid == request.auth.uid;
      }

      match /typing/{typingId} {
        allow read, write: if signedIn() && request.auth.uid in dmDoc(dmId).data.participants;
      }
    }
  }
}
